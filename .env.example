# ============================================================================
# Exemplo de configuracao. Copie para ".env" e ajuste.
#   PowerShell:  Copy-Item .env.example .env
#   Bash:        cp .env.example .env
#
# REGRA DE OURO: o sistema sobe 100% LOCAL sem nenhuma credencial.
# Os valores "local" sao o DEFAULT. So mude para cloud na demo final.
# NUNCA faca commit do arquivo .env (ele esta no .gitignore).
# ============================================================================

# ----- Selecao de backend (injecao de dependencia: local | cloud) -----
STORAGE_BACKEND=local            # local | s3
NLP_BACKEND=local                # local | comprehend
TRANSCRIPTION_BACKEND=recognize_google   # recognize_google | mock
VIDEO_BACKEND=local              # local | mock
OCR_BACKEND=local                # local | mock  (NUNCA Textract)
SUMMARIZER_BACKEND=distilbart    # distilbart | extractive

# ----- Caminhos locais -----
LOCAL_STORAGE_DIR=data/storage   # usado pelo LocalStorageAdapter

# ----- Idioma padrao da transcricao -----
TRANSCRIPTION_LANGUAGE=pt-BR

# ----- Video (YOLOv8 - local, custo zero) -----
VIDEO_MODEL=yolov8n.pt           # modelo pre-treinado
VIDEO_FOCUS_CLASSES=knife,scissors   # classes COCO monitoradas (proxy automutilacao)
VIDEO_FRAME_SAMPLE=15            # analisa 1 frame a cada N (reduz custo)
VIDEO_CONF_THRESHOLD=0.25        # confianca minima da deteccao

# ----- AWS (OPCIONAL - somente na demo final; deixe vazio para rodar local) -----
# As credenciais NUNCA ficam no repositorio. Preencha apenas no seu .env local.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# ----- App -----
APP_ENV=dev
LOG_LEVEL=INFO
